# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Data (don't commit the dataset or images)
data/raw/**/*.png
data/raw/**/*.jpg
data/raw/**/*.jpeg
data/annotations/**/*.png
data/all_labels/*.txt
data/dataset/images/**/*
data/dataset/labels/**/*

# Model weights (large binaries)
*.pt
weights/*.pt

# Classical baseline model
*.joblib

# YOLO training runs
training/runs/

# Outputs (keep the folder via .gitkeep, ignore all generated content
# including subfolders like outputs/annotated/ and outputs/gui_annotated/)
outputs/*
!outputs/.gitkeep

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp

# Keep folder structure with .gitkeep
!**/.gitkeep

# Source dataset (large; not committed)
TrainData/